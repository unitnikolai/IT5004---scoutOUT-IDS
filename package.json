{
  "name": "scoutout",
  "version": "1.0.0",
  "description": "Packet capture data viewer application",
  "main": "server/index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-deps": "npm install && cd client && npm install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0"
  },
  "devDependencies": {
    "concurrently": "^7.6.0",
    "nodemon": "^2.0.22"
  },
  "keywords": [
    "packet-capture",
    "network",
    "monitoring",
    "react",
    "express"
  ],
  "author": "",
  "license": "MIT"
}
